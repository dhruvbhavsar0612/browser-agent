{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.browser-agent.dev/marketplace/v1/skill.schema.json",
  "title": "Browser Agent skill manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "version",
    "name",
    "description",
    "instructions",
    "requiredConnectors",
    "requiredTools",
    "compatibility",
    "license",
    "provenance",
    "checksum"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "skill" },
    "id": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/id"
    },
    "version": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/version"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "instructions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.[mM][dD]$"
        }
      }
    },
    "requiredConnectors": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/reference"
      }
    },
    "requiredTools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["connectorId", "name"],
        "properties": {
          "connectorId": {
            "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/id"
          },
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "compatibility": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/compatibility"
    },
    "license": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/license"
    },
    "provenance": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/provenance"
    },
    "checksum": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/checksum"
    }
  }
}
