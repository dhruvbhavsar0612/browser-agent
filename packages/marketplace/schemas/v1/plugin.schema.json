{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.browser-agent.dev/marketplace/v1/plugin.schema.json",
  "title": "Browser Agent declarative plugin bundle manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "version",
    "name",
    "description",
    "connector",
    "skills",
    "compatibility",
    "license",
    "provenance",
    "checksum"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "plugin" },
    "id": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/id"
    },
    "version": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/version"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "connector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/id"
        },
        "version": {
          "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/version"
        },
        "config": { "$ref": "#/$defs/connectorConfig" }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version"],
        "properties": {
          "id": {
            "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/id"
          },
          "version": {
            "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/version"
          },
          "config": {
            "type": "object",
            "additionalProperties": false,
            "properties": { "enabled": { "type": "boolean" } }
          }
        }
      }
    },
    "compatibility": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/compatibility"
    },
    "license": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/license"
    },
    "provenance": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/provenance"
    },
    "checksum": {
      "$ref": "https://schemas.browser-agent.dev/marketplace/v1/common.schema.json#/$defs/checksum"
    }
  },
  "$defs": {
    "setting": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["value"],
          "properties": {
            "value": { "type": ["string", "number", "boolean"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["secret"],
          "properties": { "secret": { "type": "string", "minLength": 1 } }
        }
      ]
    },
    "connectorConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "variables": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/setting" }
        }
      }
    }
  }
}
