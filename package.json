{
  "name": "browser-agent",
  "private": true,
  "version": "0.0.1",
  "description": "BYOK browser AI agent extension",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "pack:extension": "node scripts/pack-extension.mjs",
    "sync:version": "node scripts/sync-version.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
